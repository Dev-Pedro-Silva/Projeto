@model List<ProjetoBiblioteca.Models.Livro>

<h1>Catálogo de Livros</h1>

<table class="table">
    <thead>
        <tr>
            <th>Título</th>
            <th>Autor</th>
            <th>Categoria</th>
            <th>Preço</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var livro in Model)
        {
            <tr>
                <td>@livro.Titulo</td>
                <td>@livro.Autor</td>
                <td>@livro.Categoria</td>
                <td>R$ @livro.Preco</td>
            </tr>
        }
    </tbody>
</table>