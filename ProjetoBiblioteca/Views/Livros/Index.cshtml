@model IEnumerable<ProjetoBiblioteca.Models.Livro>


@if (User.Identity?.IsAuthenticated == true)
{
    ViewData["Title"] = "Gerenciar Livros";
}
else
{
    ViewData["Title"] = "Livros";
}


@if (User.Identity?.IsAuthenticated == true)
{
    <h2>Gerenciamento de Livros</h2>
}
else
{
    <h2>Catálogo de Livros</h2>
}


<p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-success mb-3">
            Novo Livro
        </a>
    }
</p>

<form asp-action="Index" method="get" class="mb-3">

    <div class="input-group">

        <input type="text" name="pesquisa" class="form-control form-control-lg"
               placeholder="🔍 Pesquisar por título ou autor..." />

        <button class="btn btn-primary" type="submit">

            Pesquisar

        </button>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">

            Nenhum livro encontrado.

        </div>
    }

</form>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card h-100 shadow-sm">

                <img src="@(string.IsNullOrWhiteSpace(item.ImagemUrl)
                                                                                        ? "https://placehold.co/400x600?text=Sem+Imagem"
                                                                                        : item.ImagemUrl)" class="card-img-top"
                     style="height:300px; object-fit:cover;" alt="@item.Titulo">

                <div class="card-body">

                    <h5 class="card-title">

                        @item.Titulo

                    </h5>

                    <p class="text-muted">

                        @item.Autor

                    </p>

                    <span class="badge bg-primary">

                        @item.Categoria

                    </span>

                    <hr>

                    <p>

                        @(item.Descricao.Length > 120
                            ? item.Descricao.Substring(0, 120) + "..."
                            : item.Descricao)

                    </p>

                    @if (item.Disponivel)
                    {
                        <p class="text-success fw-bold">

                            🟢 Disponível

                        </p>
                    }
                    else
                    {
                        <p class="text-danger fw-bold">

                            🔴 Indisponível

                        </p>
                    }

                </div>

                <div class="card-footer bg-white">

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm">

                        Ver detalhes

                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">

                            Editar

                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">

                            Excluir

                        </a>
                    }

                </div>

            </div>

        </div>
    }

</div>