@model ProjetoBiblioteca.Models.Livro

@{
    ViewData["Title"] = "Excluir Livro";
}

<h2>Excluir Livro</h2>

<div class="alert alert-danger">
    <strong>Tem certeza que deseja excluir este livro?</strong>
</div>

<dl class="row">

    <dt class="col-sm-2">
        Título
    </dt>

    <dd class="col-sm-10">
        @Model.Titulo
    </dd>

    <dt class="col-sm-2">
        Autor
    </dt>

    <dd class="col-sm-10">
        @Model.Autor
    </dd>

    <dt class="col-sm-2">
        Categoria
    </dt>

    <dd class="col-sm-10">
        @Model.Categoria
    </dd>

    <dt class="col-sm-2">
        Preço
    </dt>


</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Excluir
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>

</form>