@model ProjetoBiblioteca.Models.Livro

@{
    ViewData["Title"] = "Detalhes do Livro";
}

<div class="container mt-4">

    <div class="row">

        <div class="col-md-4">

            <img src="@Model.ImagemUrl" class="img-fluid rounded shadow" alt="@Model.Titulo">

        </div>

        <div class="col-md-8">

            <h2>@Model.Titulo</h2>

            <p>
                <strong>Autor:</strong>
                @Model.Autor
            </p>

            <p>
                <strong>Categoria:</strong>
                @Model.Categoria
            </p>

            @if (Model.Disponivel)
            {
                <span class="badge bg-success">

                    Disponível

                </span>
            }
            else
            {
                <span class="badge bg-danger">

                    Indisponível

                </span>
            }

            <hr />

            <h4>Descrição</h4>

            <p>
                @Model.Descricao
            </p>

            <a asp-action="Index" class="btn btn-secondary">
                Voltar
            </a>

        </div>

    </div>

</div>