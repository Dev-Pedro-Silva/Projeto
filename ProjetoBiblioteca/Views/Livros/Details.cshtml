@model ProjetoBiblioteca.Models.Livro

@{
    ViewData["Title"] = "Detalhes do Livro";
}

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">

        @TempData["Sucesso"]

    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">

        @TempData["Erro"]

    </div>
}

<div class="container mt-4">

    <div class="row">

        <div class="col-md-4">

            <img src="@Model.ImagemUrl" class="img-fluid rounded shadow" alt="@Model.Titulo">

        </div>

        <div class="col-md-8">

            <h2>@Model.Titulo</h2>

            <p>
                <strong>Autor:</strong>
                @Model.Autor
            </p>

            <p>
                <strong>Categoria:</strong>
                @Model.Categoria
            </p>

            @if (Model.Disponivel)
            {
                <span class="badge bg-success">

                    🟢 Disponível para empréstimo

                </span>
            }
            else
            {
                <span class="badge bg-danger">

                    🔴 Empréstimo indisponível

                </span>
            }

            @if (Model.Disponivel)
            {
                <div class="mt-4">

                    <a asp-action="Emprestar" asp-route-id="@Model.Id" class="btn btn-success">

                        📚 Solicitar Empréstimo

                    </a>

                </div>
            }
            else
            {
                <div class="mt-4">

                    <button class="btn btn-secondary" disabled>

                        Livro indisponível

                    </button>

                </div>
            }

            <hr />

            <h4>Descrição</h4>

            <p>
                @Model.Descricao
            </p>

            <a asp-action="Index" class="btn btn-secondary">
                Voltar
            </a>

        </div>

    </div>

</div>