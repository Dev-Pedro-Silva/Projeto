@model ProjetoBiblioteca.Models.Servico

@{
    ViewData["Title"] = "Detalhes do Serviço";
}

<div class="container mt-4">

    <div class="row">

        <div class="col-md-4">

            <img src="@(string.IsNullOrWhiteSpace(Model.ImagemUrl)
                ? "https://placehold.co/400x600?text=Sem+Imagem"
                : Model.ImagemUrl)"
                 class="img-fluid rounded shadow"
                 alt="@Model.Nome"/>

        </div>

        <div class="col-md-8">

            <h2>@Model.Nome</h2>

            <p>
                <strong>Categoria:</strong>
                @Model.Categoria
            </p>

            <p>
                <strong>Valor:</strong>
                R$ @Model.Valor.ToString("N2")
            </p>

            <hr>

            <h4>Descrição</h4>

            <p>@Model.Descricao</p>

            <a asp-action="Index"
               class="btn btn-secondary">

                Voltar

            </a>

        </div>

    </div>

</div>