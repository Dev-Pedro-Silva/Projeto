@model IEnumerable<ProjetoBiblioteca.Models.Servico>

@if (User.Identity?.IsAuthenticated == true)
{
    ViewData["Title"] = "Gerenciar Serviços";
}
else
{
    ViewData["Title"] = "Serviços";
}


@if (User.Identity?.IsAuthenticated == true)
{
    <h2>Gerenciamento de Serviços</h2>
}
else
{
    <h2>Catálogo de Serviços</h2>
}

<p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-success mb-3">
            Novo Serviço
        </a>
    }
</p>

<form asp-action="Index" method="get" class="mb-3">

    <div class="input-group">

        <input type="text" name="pesquisa" class="form-control form-control-lg" placeholder="🔍 Pesquisar serviço..." />

        <button class="btn btn-primary" type="submit">

            Pesquisar

        </button>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">

            Nenhum serviço encontrado.

        </div>
    }

</form>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card shadow-sm h-100">

                <img src="@(string.IsNullOrWhiteSpace(item.ImagemUrl)
                                                          ? "https://placehold.co/400x600?text=Sem+Imagem"
                                                          : item.ImagemUrl)" class="card-img-top" style="height:320px; object-fit:cover;"
                     alt="@item.Nome" />

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">
                        @item.Nome
                    </h5>

                    <span class="badge bg-primary mb-3">
                        @item.Categoria
                    </span>

                    <p class="card-text">
                        @(item.Descricao.Length > 100
                            ? item.Descricao.Substring(0, 100) + "..."
                            : item.Descricao)
                    </p>

                    <p class="fw-bold text-success">
                        R$ @item.Valor.ToString("N2")
                    </p>

                    <div class="mt-auto">

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 mb-2">

                            Ver detalhes

                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="d-grid gap-2">

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">

                                    Editar

                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">

                                    Excluir

                                </a>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>
    }

</div>