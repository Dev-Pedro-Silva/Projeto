@{
    ViewData["Title"] = "Sobre";
}

<div class="container mt-4">

    <div class="text-center mb-5">
        <h1 class="display-5">📚 Sobre a Biblioteca Digital</h1>
        <p class="lead">
            Conheça um pouco mais sobre o nosso sistema e seus objetivos.
        </p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h3>📖 Nossa História</h3>

            <p>
                A Biblioteca Digital foi desenvolvida com o objetivo de facilitar
                a consulta ao acervo de livros e aos serviços oferecidos pela
                biblioteca. A plataforma busca proporcionar uma experiência simples,
                organizada e intuitiva para todos os usuários.
            </p>

        </div>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100">

                <div class="card-body">

                    <h3>🎯 Missão</h3>

                    <p>
                        Incentivar o acesso ao conhecimento por meio de uma
                        plataforma prática e organizada para consulta do acervo.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100">

                <div class="card-body">

                    <h3>👁 Visão</h3>

                    <p>
                        Tornar a consulta de livros e serviços cada vez mais
                        acessível e eficiente para todos os usuários.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100">

                <div class="card-body">

                    <h3>🤝 Valores</h3>

                    <ul>
                        <li>Organização</li>
                        <li>Compromisso</li>
                        <li>Acessibilidade</li>
                        <li>Conhecimento</li>
                    </ul>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <h3>💻 Tecnologias Utilizadas</h3>

            <div class="row text-center mt-4">

                <div class="col-md-3">
                    <h5>ASP.NET Core MVC</h5>
                </div>

                <div class="col-md-3">
                    <h5>Entity Framework Core</h5>
                </div>

                <div class="col-md-3">
                    <h5>SQLite</h5>
                </div>

                <div class="col-md-3">
                    <h5>Bootstrap 5</h5>
                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <h3>🎓 Projeto Acadêmico</h3>

            <p>
                Este sistema foi desenvolvido como projeto da disciplina de
                Programação Web, utilizando a arquitetura MVC para aplicar
                conceitos de desenvolvimento web, organização em camadas,
                autenticação de usuários e persistência de dados com
                Entity Framework Core e SQLite.
            </p>

        </div>

    </div>

    <div class="text-center mt-5 text-muted">

        <p>
            Desenvolvido por <strong>Pedro Henrique Silva de Oliveira</strong>
            como projeto acadêmico.
        </p>

    </div>

</div>