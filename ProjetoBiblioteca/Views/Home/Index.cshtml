@model List<ProjetoBiblioteca.Models.Livro>

@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-5 bg-light rounded-4 shadow">

    <div class="text-center">

        <h1 class="display-4 mb-3">
            📚 Biblioteca Digital
        </h1>

        <p class="lead">
            Bem-vindo à Biblioteca Digital! Nossa plataforma foi desenvolvida para facilitar
            a consulta ao acervo de livros e aos serviços oferecidos pela biblioteca,
            proporcionando uma experiência simples, organizada e intuitiva.
        </p>

        <hr class="my-4"/>

        <p>
            Explore nosso catálogo, conheça os serviços disponíveis e descubra
            um ambiente pensado para incentivar o acesso ao conhecimento.
        </p>

        <a asp-controller="Livros"
           asp-action="Index"
           class="btn btn-primary btn-lg me-3">

            📚 Ver Livros

        </a>

        <a asp-controller="Servicos"
           asp-action="Index"
           class="btn btn-outline-primary btn-lg">

            🛠 Ver Serviços

        </a>

    </div>

</div>

<h2 class="mb-4">

    Últimos livros cadastrados

</h2>

@if(Model.Any())
{
    <div class="row">

        @foreach(var livro in Model)
        {
            <div class="col-lg-4 mb-4">

                <div class="card shadow-sm h-100">

                    <img src="@(string.IsNullOrWhiteSpace(livro.ImagemUrl)
                        ? "https://placehold.co/400x600?text=Sem+Capa"
                        : livro.ImagemUrl)"
                         class="card-img-top"
                         style="height:320px; object-fit:cover;"
                         alt="@livro.Titulo"/>

                    <div class="card-body">

                        <h5>@livro.Titulo</h5>

                        <p class="text-muted">

                            @livro.Autor

                        </p>

                        <span class="badge bg-primary">

                            @livro.Categoria

                        </span>

                        <hr>

                        <p>

                            @(livro.Descricao.Length > 120
                                ? livro.Descricao.Substring(0,120) + "..."
                                : livro.Descricao)

                        </p>

                    </div>

                    <div class="card-footer bg-white">

                        <a asp-controller="Livros"
                           asp-action="Details"
                           asp-route-id="@livro.Id"
                           class="btn btn-outline-primary w-100">

                            Ver detalhes

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="alert alert-info">

        Ainda não existem livros cadastrados.

    </div>
}