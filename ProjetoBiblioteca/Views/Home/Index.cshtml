@model List<ProjetoBiblioteca.Models.Livro>

@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
    <div class="container py-4">

        <h1 class="display-4">📚 Biblioteca Digital</h1>

        <p class="lead">
            Seu portal para consulta de livros e serviços da biblioteca.
        </p>

        <a asp-controller="Livros" asp-action="Index" class="btn btn-primary btn-lg me-2">
            Ver Livros
        </a>

        <a asp-controller="Servicos" asp-action="Index" class="btn btn-outline-primary btn-lg">
            Ver Serviços
        </a>

    </div>
</div>

<div class="row">

    <div class="col-md-4 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body">

                <h3>📚 Acervo</h3>

                <p>
                    Consulte todos os livros cadastrados em nossa biblioteca.
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body">

                <h3>🛠 Serviços</h3>

                <p>
                    Conheça todos os serviços oferecidos pela biblioteca.
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-4">

        <div class="card shadow-sm h-100">

            <div class="card-body">

                <h3>🔒 Administração</h3>

                <p>
                    Área exclusiva para gerenciamento do sistema.
                </p>

            </div>

        </div>

    </div>

</div>

<hr class="my-5" />

<h2 class="mb-4">Últimos livros cadastrados</h2>

@if (Model.Any())
{
    <div class="row">

        @foreach (var livro in Model)
        {
            <div class="col-md-4 mb-3">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h5>@livro.Titulo</h5>

                        <p class="text-muted">

                            @livro.Autor

                        </p>

                        <p class="mb-2">
                            <strong>Categoria:</strong> @livro.Categoria
                        </p>

                        <p class="text-primary fw-bold">
                            R$ @livro.Preco.ToString("N2")
                        </p>

                    </div>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="alert alert-info">
        Nenhum livro cadastrado até o momento.
    </div>
}